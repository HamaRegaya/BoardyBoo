# ═══════════════════════════════════════════════════════════════════════════════
# BoardyBoo Backend — Environment Variables
# Copy this to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Google AI ─────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your-gemini-api-key
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Set to true to use Vertex AI instead of direct API
GOOGLE_GENAI_USE_VERTEXAI=false

# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_PATH=./boardyboo-firebase-adminsdk-fbsvc-XXXXXXXX.json
FIRESTORE_DATABASE=(default)

# ── Google Cloud Storage ──────────────────────────────────────────────────────
GCS_BUCKET=your-gcs-bucket-name

# ── Google OAuth (for Calendar & Gmail integration) ───────────────────────────
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
