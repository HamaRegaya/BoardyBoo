# Google AI / Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your-gemini-api-key
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Models
TUTOR_AGENT_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
PLANNER_AGENT_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
CANVAS_AGENT_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
CALENDAR_AGENT_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
MEDIA_AGENT_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
PROGRESS_AGENT_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
IMAGE_GENRATION_MODEL=gemini-3-pro-image-preview

# MCP GenMedia
GENMEDIA_MCP_SERVER_URL=http://localhost:8081
GENMEDIA_BUCKET=your-gcs-bucket-for-media

# Google Calendar & Gmail OAuth
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret

# Firestore
FIRESTORE_DATABASE=(default)

# Cloud Storage
GCS_BUCKET=your-gcs-bucket

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
CORS_ORIGINS=["http://localhost:3000"]

#Firebase
FIREBASE_SERVICE_ACCOUNT_PATH="./path/to/your/firebase-adminsdk.json"
FIREBASE_PROJECT_ID=your-firebase-project-id
